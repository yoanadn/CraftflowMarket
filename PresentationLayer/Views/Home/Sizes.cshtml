<section class="section-block size-guide-page">
    <div class="section-head">
        <h2>Пръстени - EU</h2>
    </div>
    <p class="soft-text">Числата в EU размера показват вътрешната обиколка на пръстена в мм. Пример: EU 54 означава обиколка 54 мм.</p>
    <div class="size-table-wrap">
        <table class="size-table">
            <thead>
                <tr>
                    <th>EU размер</th>
                    <th>Обиколка на пръста мм</th>
                </tr>
            </thead>
            <tbody>
                @for (decimal size = 46m; size <= 66m; size += 0.5m)
                {
                    var displaySize = size % 1m == 0m
                        ? size.ToString("0", System.Globalization.CultureInfo.InvariantCulture)
                        : size.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
                    <tr><td>@displaySize</td><td>@displaySize</td></tr>
                }
            </tbody>
        </table>
    </div>
</section>
