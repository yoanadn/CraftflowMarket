@model RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<section class="auth-shell">
    <div class="auth-card">
        <h1>Създай профил</h1>
        <p class="soft-text">Регистрирай се веднъж и започни да запазваш любими продукти и да правиш поръчки.</p>

        <form asp-action="Register" method="post" class="auth-form">
            <label>
                Потребителско име
                <input asp-for="Username" />
                <span asp-validation-for="Username" class="field-validation-error"></span>
            </label>

            <label>
                Имейл
                <input asp-for="Email" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </label>

            <div class="auth-grid-2">
                <label>
                    Име
                    <input asp-for="FirstName" />
                    <span asp-validation-for="FirstName" class="field-validation-error"></span>
                </label>

                <label>
                    Фамилия
                    <input asp-for="LastName" />
                    <span asp-validation-for="LastName" class="field-validation-error"></span>
                </label>
            </div>

            <div class="auth-grid-2">
                <label>
                    Парола
                    <input asp-for="Password" />
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </label>

                <label>
                    Потвърди парола
                    <input asp-for="ConfirmPassword" />
                    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                </label>
            </div>

            <div asp-validation-summary="ModelOnly" class="field-validation-error"></div>
            <button type="submit" class="btn-main wide-btn">Регистрация</button>
        </form>

        <p class="auth-foot-note">
            Вече имаш профил?
            <a asp-action="Login">Вход</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
